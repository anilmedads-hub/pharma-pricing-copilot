# ===========================================================================
# Pharma Pricing Copilot — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Anthropic API
# ---------------------------------------------------------------------------
# Required for the AI Copilot, Regulatory Q&A (RAG), and embedding features.
# Obtain your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Data directories
# ---------------------------------------------------------------------------
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# Path where the FAISS vector store index is persisted
VECTOR_STORE_PATH=data/processed/vector_store

# ---------------------------------------------------------------------------
# Simulation defaults
# ---------------------------------------------------------------------------
RANDOM_SEED=42
N_DRUGS=20
HISTORY_MONTHS=36
ANOMALY_RATE=0.04

# ---------------------------------------------------------------------------
# Streamlit
# ---------------------------------------------------------------------------
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
